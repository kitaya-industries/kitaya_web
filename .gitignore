# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js

# ── Next.js build output ──────────────────────────────────────────────────────
# FIXED: .next/ was present in the committed file tree — build output should
# never be in git. Vercel builds this fresh on every deploy.
/.next/
/out/

# ── Environment variables ─────────────────────────────────────────────────────
# CRITICAL: These contain your Supabase service role key, Razorpay secret,
# Delhivery token, and Resend API key. Must NEVER be committed.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── macOS system files ────────────────────────────────────────────────────────
# FIXED: .DS_Store files were committed throughout the repo.
# Run: git rm -r --cached .DS_Store to remove already-tracked ones.
.DS_Store
**/.DS_Store

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Misc ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.next/
.next/
node_modules/
